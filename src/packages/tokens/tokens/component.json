{
  "button": {
    "primary": {
      "bg":       { "$value": "{color.bg.brand}",       "$type": "color" },
      "bg-hover": { "$value": "{color.bg.brand-hover}", "$type": "color" },
      "text":     { "$value": "{color.text.inverse}",   "$type": "color" }
    },
    "secondary": {
      "bg":       { "$value": "{color.bg.surface}",     "$type": "color" },
      "bg-hover": { "$value": "{color.bg.muted}",       "$type": "color" },
      "text":     { "$value": "{color.text.primary}",   "$type": "color" },
      "border":   { "$value": "{color.border.default}", "$type": "color" }
    },
    "radius":     { "$value": "{radius.md}",     "$type": "dimension" },
    "fontWeight": { "$value": "{fontWeight.semibold}", "$type": "fontWeight" }
  },
  "card": {
    "bg":     { "$value": "{color.bg.surface}",     "$type": "color" },
    "border": { "$value": "{color.border.default}", "$type": "color" },
    "radius": { "$value": "{radius.lg}",            "$type": "dimension" },
    "padding":{ "$value": "{space.5}",              "$type": "dimension" }
  },
  "input": {
    "bg":          { "$value": "{color.bg.canvas}",     "$type": "color" },
    "border":      { "$value": "{color.border.default}","$type": "color" },
    "borderFocus": { "$value": "{color.border.focus}",  "$type": "color" },
    "radius":      { "$value": "{radius.md}",           "$type": "dimension" }
  }
}